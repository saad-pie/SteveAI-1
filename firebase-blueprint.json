{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific metadata and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth ID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user first signed in" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system" }
      },
      "required": ["uid", "email", "role"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID" },
        "role": { "type": "string", "enum": ["user", "assistant"], "description": "Who sent the message" },
        "content": { "type": "string", "description": "The text content of the message" },
        "timestamp": { "type": "number", "description": "Unix timestamp of the message" },
        "model": { "type": "string", "description": "The AI model used for the response" },
        "userId": { "type": "string", "description": "The ID of the user who owns this message" }
      },
      "required": ["role", "content", "timestamp", "userId"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A collection of chat messages representing a single conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique session ID" },
        "title": { "type": "string", "description": "The title of the chat session" },
        "createdAt": { "type": "number", "description": "Unix timestamp of session creation" },
        "lastMessage": { "type": "string", "description": "The content of the last message in the session" },
        "userId": { "type": "string", "description": "The ID of the user who owns this session" }
      },
      "required": ["title", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat sessions for a specific user"
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Individual chat messages for a specific session"
    }
  }
}
